rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: uid
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - name: string (required)
    //   - role: string (required, enum: ["super_admin", "institute_admin", "student"])
    //   - instituteId: string (optional)
    //
    // Collection: institutes
    // Document ID: auto-generated
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - adminUid: string (required)
    //   - status: string (required, enum: ["pending", "approved", "rejected"])
    //   - createdAt: timestamp (required)
    //
    // Sub-collection: institutes/{id}/students
    // Document ID: auto-generated
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - email: string (required)
    //   - instituteId: string (required)
    //   - addedBy: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "omkhalkar9995@gmail.com" && request.auth.token.email_verified == true);
    }

    function isInstituteAdmin(instituteId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "institute_admin" &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.instituteId == instituteId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             data.name is string && data.name.size() > 0 &&
             data.role in ["super_admin", "institute_admin", "student"];
    }

    function isValidInstitute(data) {
      return data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.adminUid is string && data.adminUid.size() > 0 &&
             data.adminEmail is string && data.adminEmail.size() > 0 &&
             data.adminName is string && data.adminName.size() > 0 &&
             data.status in ["pending", "approved", "rejected"] &&
             data.createdAt is timestamp;
    }

    function isInstituteOwner(instituteData) {
      return isAuthenticated() && request.auth.uid == instituteData.adminUid;
    }

    function isValidStudent(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.instituteId is string && data.instituteId.size() > 0 &&
             data.addedBy is string && data.addedBy.size() > 0 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isSuperAdmin();
      allow create: if isAuthenticated() && isOwner(uid) && isValidUser(request.resource.data) && 
                    (request.resource.data.role != "super_admin" || isSuperAdmin());
      allow update: if isSuperAdmin() || (isOwner(uid) && isValidUser(request.resource.data) && 
                    request.resource.data.role == resource.data.role);
    }

    match /institutes/{id} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidInstitute(request.resource.data) && 
                    request.resource.data.status == "pending" && 
                    request.resource.data.adminUid == request.auth.uid;
      allow update: if (isSuperAdmin() || (isInstituteOwner(resource.data) && request.resource.data.status == resource.data.status)) && 
                    isValidInstitute(request.resource.data);
      
      match /students/{studentId} {
        allow read: if isSuperAdmin() || isInstituteAdmin(id);
        allow write: if (isSuperAdmin() || isInstituteAdmin(id)) && isValidStudent(request.resource.data);
      }
    }

    match /colleges/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
